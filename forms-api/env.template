# Configuración del microservicio de formularios
# Copiar este archivo como .env en el directorio forms/ y ajustar los valores según tu entorno

# Base de Datos MySQL
# NOTA: Cuando se ejecuta en Docker, DB_HOST debe ser "mysql" (nombre del servicio en docker-compose)
# Cuando se ejecuta localmente, usar "localhost"
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
# IMPORTANTE: Debe coincidir con MYSQL_ROOT_PASSWORD en docker-compose.yml
# ⚠️ CAMBIAR en producción por una contraseña segura
DB_PASSWORD=secret
DB_NAME=app_db

# Credenciales MySQL para docker-compose (usadas por el servicio mysql)
# ⚠️ CAMBIAR en producción por contraseñas seguras
MYSQL_ROOT_PASSWORD=secret
MYSQL_DATABASE=app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password

# Configuración del Servidor
SERVER_PORT=8080

# Directorios de Almacenamiento
# Rutas relativas al directorio de trabajo de la aplicación
EMAILS_DIR=src/emails
IMAGES_DIR=src/img

# Integración con otros Microservicios
# URL del servicio de usuarios (users-api)
USERS_API_URL=http://users-api:3000

# JWT Configuración
# ⚠️ CRÍTICO: Este JWT_SECRET debe ser EXACTAMENTE el mismo que en users-api
# Si no coinciden, la autenticación entre servicios fallará
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Login Service URL (legacy, mantenido para compatibilidad)
LOGIN_SERVICE_URL=http://localhost:8080

